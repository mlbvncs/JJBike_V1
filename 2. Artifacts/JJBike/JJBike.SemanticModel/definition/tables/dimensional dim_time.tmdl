	column 'time_date (bins)' =
			IF(
				ISBLANK('dimensional dim_time'[time_date]),
				BLANK(),
				DATE(
					YEAR('dimensional dim_time'[time_date]),
					1 + (MONTH('dimensional dim_time'[time_date]) - 1),
					1
				)
			)
		formatString: mmmm" de "yyyy
